  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      },
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-4.1-mini"
      },
      "models": {
        "anthropic/claude-opus-4-6": {},
        "anthropic/claude-3-5-sonnet-20240620": {},
        "anthropic/claude-sonnet-4-6": {},
        "openai/gpt-4.1-mini": {}
      },
      "workspace": "/data/.openclaw/workspace",
      "maxConcurrent": 8,
      "subagents": {
        "maxConcurrent": 6
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Main Agent",
        "workspace": "/data/.openclaw/workspace",
        "agentDir": "/data/.openclaw/agents/main/agent",
        "model": {
          "primary": "anthropic/claude-opus-4-6"
        }
      },
      {
        "id": "wev-eng-1",
        "default": false,
        "workspace": "/data/.openclaw/workspace-wev-eng-1",
        "agentDir": "/data/.openclaw/agents/wev-eng-1/agent",
        "identity": {
          "name": "wev-eng-1"
        }
      }
    ]
  },
  "tools": {
    "profile": "full"
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "wev-eng-1",
      "match": {
        "channel": "telegram",
        "accountId": "wev-eng1-bot"
      }
    }
  ],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "resetByType": {
